{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "track_desk",
  "version": "0.1.0",
  "identifier": "com.dev.track_desk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "TrackDesk",
        "width": 380,
        "height": 720,
        "minWidth": 340,
        "minHeight": 560,
        "visible": true
      },
      {
        "label": "dev",
        "url": "index.html#/dev",
        "title": "TrackDesk — Dev Inspector",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 500,
        "resizable": true,
        "visible": false
      },
      {
        "label": "widget",
        "url": "index.html#/widget",
        "title": "TrackDesk Widget",
        "width": 232,
        "height": 150,
        "x": 0,
        "y": 0,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
